DATABASE_URL=sqlite:///./focusflow.db
# For production (Railway): DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Auth: required for JWT (use a long random string in production)
SECRET_KEY=change-me-in-production-use-long-random-string

# Password reset email: frontend URL for reset link
FRONTEND_URL=http://localhost:3000
# Optional SMTP for sending reset emails (if not set, reset link is returned in API response for dev)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=noreply@yourdomain.com

# Required for AI prioritization, chat, schedule recommend
OPENAI_API_KEY=sk-your-key-here
# Optional: OPENAI_MODEL=gpt-4o-mini  (default)
